# Configuración de Google OAuth2 (para Login de usuarios)
GOOGLE_CLIENT_ID="TU_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="TU_GOOGLE_CLIENT_SECRET"
GOOGLE_REDIRECT_URI="http://localhost:8501"

# Configuración de Google Sheets
GOOGLE_SHEET_ID="ID_DE_TU_HOJA_DE_CALCULO"
GOOGLE_SHEET_RANGE="Sheet1!A:F"

# Credenciales de Cuenta de Servicio (para escribir en Google Sheets)
# Puedes pegar el contenido del archivo JSON directamente aquí en una sola línea entre comillas simples:
GOOGLE_SERVICE_ACCOUNT_JSON='{"type": "service_account", "project_id": ...}'

# O bien, si prefieres, puedes guardar tu JSON de cuenta de servicio como "google-credentials.json"
# en este directorio y usar la siguiente variable (descomentándola):
# GOOGLE_SERVICE_ACCOUNT_FILE="google-credentials.json"
